PORT=5000
SUPABASE_URL=
SUPABASE_KEY=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Create one Walfi bot in BotFather, then add its token and public username here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=WalfiBot

# This must be a public HTTPS endpoint: https://your-api.example.com/api/webhooks/telegram
TELEGRAM_WEBHOOK_URL=https://your-api.example.com/api/webhooks/telegram
# Generate a long random value and keep it secret. Telegram sends it with every webhook request.
TELEGRAM_WEBHOOK_SECRET=

# Helius sends tracked-wallet swaps to this public HTTPS endpoint.
HELIUS_API_KEY=
HELIUS_WEBHOOK_ID=
WEBHOOK_URL=https://your-api.example.com/api/webhooks/helius

# Used to check the connected wallet has enough SOL before preparing a copy trade.
SOLANA_RPC=https://api.mainnet-beta.solana.com
